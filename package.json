{
  "name": "lms-erp-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "admin-ui",
    "user-ui",
    "whatsapp-bot"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w backend",
    "dev:admin": "npm run dev -w admin-ui",
    "dev:user": "npm run dev -w user-ui",
    "dev:whatsapp": "npm run dev -w whatsapp-bot",
    "build:backend": "npm run build -w backend",
    "build:admin": "npm run build -w admin-ui",
    "build:user": "npm run build -w user-ui",
    "build:whatsapp": "npm run build -w whatsapp-bot",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "playwright": "^1.61.1",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}



{
  "name": "whatsapp-bot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@whiskeysockets/baileys": "6.7.23",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/qrcode-terminal": "^0.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts,json",
    "ignore": [
      "auth/*",
      "node_modules/*",
      "dist/*",
      "../auth/*",
      "/tmp/*"
    ],
    "delay": 5000
  }
}
